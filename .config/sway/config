assign [title="Gemini"] $ws4
assign [title="Google Chat"] $ws4
assign [title="Google Translate"] $ws4
assign [title="Telegram Web"] $ws4
# Desktop 5: Commsn
assign [title="Google Calendar"] $ws5
assign [title="Gmail"] $ws5
# Desktop 8: Media
assign [title="Amazon Music"] $ws8

# Windows specific settings
for_window [class="Xfce4-terminal"] border pixel 3

# Open specific applications in floating mode
# Wayand windows properties can be obtained by reading the wayland tree with a command like this:
# $ sleep 2 ; swaymsg -t get_tree | jq '.. | select(.type?) | select(.focused==true)'
# and ensuring to focus the window to get the properties for,
for_window [app_id="org.gnome.Calculator"] floating enable
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [app_id="sanity-check"] floating enable, resize set 800 600, move position center
for_window [app_id="system-monitor"] floating enable, resize set width 80 ppt height 80 ppt, move position center
for_window [app_id="calendar"] floating enable, resize set width 40 ppt height 55 ppt, move position center
for_window [app_id="battery-report"] floating enable, resize set 800 600, move position center
for_window [class="Lxappearance"] floating enable
for_window [title="La7 in diretta"] floating enable

# switch to workspace with urgent window automatically
for_window [urgent=latest] focus

