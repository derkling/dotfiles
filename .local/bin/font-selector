#!/bin/bash
# ~/.local/bin/font-selector - Interactively choose and set a new font for multiple components

set -euo pipefail

ALACRITTY_CONFIG="$HOME/.config/alacritty/alacritty.toml"
SWAY_CONFIG="$HOME/.config/sway/config"
WAYBAR_STYLE="$HOME/.config/waybar/style.css"
FONT_DIR="$HOME/.local/share/fonts"

# Function to check if a file exists
check_file() {
    if [ ! -f "$1" ]; then
        echo "Warning: File not found at $1"
        return 1
    fi
    return 0
}

# Ask the user if they want to download more fonts
echo "More fonts available for download from: https://www.programmingfonts.org/"
read -p "Would you like to check for new fonts to download? (y/N) " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    echo "Please download new font zip files to $FONT_DIR"
    echo "Press any key to continue after you have downloaded the files."
    read -n 1 -s -r

    # Check for new zip files and unzip them
    if ls "$FONT_DIR"/*.zip 1> /dev/null 2>&1; then
        echo "New zip files found. Unzipping..."
        for zip_file in "$FONT_DIR"/*.zip; do
            unzip -o "$zip_file" -d "$FONT_DIR"
            rm "$zip_file"
        done
        echo "Rebuilding font cache..."
        fc-cache -fv
        echo "Font cache rebuilt."
    else
        echo "No new zip files found in $FONT_DIR."
    fi
fi

# Get a unique, sorted list of monospaced fonts and let the user choose
# We trim leading/trailing whitespace from the family name
selected_font=$(fc-list :mono | cut -d: -f2 | sed 's/^ //' | sort -u | fzf --prompt="Select a new font > ")

# Exit if no font was selected (user pressed Esc or Ctrl-C)
if [ -z "$selected_font" ]; then
    echo "No font selected. Exiting."
    exit 0
fi

echo "Selected font: $selected_font"

# 1. Update Alacritty
if check_file "$ALACRITTY_CONFIG"; then
    sed -i -E 's/(family\s*=\s*")[^"]*(".*)/\1'"$selected_font"'\2/' "$ALACRITTY_CONFIG"
    echo "Updated Alacritty config."
fi

# 2. Update Sway
if check_file "$SWAY_CONFIG"; then
    # Matches 'font pango:Font Name Regular, 12' or similar
    # We preserve the style and size
    sed -i -E 's/^(font pango:)[^,]+(,[[:space:]]*[0-9]+)/\1'"$selected_font"'\2/' "$SWAY_CONFIG"
    echo "Updated Sway config."
fi

# 3. Update Waybar
if check_file "$WAYBAR_STYLE"; then
    # Matches 'font-family: "Font Name", ...;'
    # We replace the first quoted family
    sed -i -E 's/(font-family:[[:space:]]*")[^"]+(")/\1'"$selected_font"'\2/' "$WAYBAR_STYLE"
    echo "Updated Waybar style."
fi

# 4. Update GSettings (GTK applications)
if command -v gsettings >/dev/null; then
    gsettings set org.gnome.desktop.interface font-name "$selected_font 10"
    echo "Updated GSettings (GTK font)."
fi

# 5. Reload configurations
echo "Reloading configurations..."
if pgrep sway >/dev/null; then
    swaymsg reload >/dev/null
fi
if pgrep waybar >/dev/null; then
    pkill -USR2 waybar
fi

echo "Successfully updated font to: $selected_font"
echo "All supported components (Alacritty, Sway, Waybar, GTK) have been updated."
