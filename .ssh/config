# ~/.ssh/config - Public SSH configuration
# This file is tracked in the public dotfiles repository.

# Load profile-specific configurations (local-only, not tracked)
Include config.d/*

# Generic SSH settings
Host *
    # PreferredAuthentications publickey
    # ControlMaster auto
    # ControlPath ~/.ssh/master-%r@%h:%p
    # ControlPersist 10m
    ServerAliveInterval 60
    ServerAliveCountMax 5

# GitHub specific (Public example)
# Test connection with: ssh -T git@github.com
Host github.com
    User git
    IdentityFile ~/.ssh/github.ssh_key
